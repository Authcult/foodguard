# ============================================================
# LLM 后端选择：ollama（本地）或 deepseek（云端）
# ============================================================
LLM_BACKEND=ollama

# --- Ollama 配置（本地部署，默认） ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# --- DeepSeek 配置（云端 API，备用） ---
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# LLM 温度（0-1，越低越精确，越高越有创意）
LLM_TEMPERATURE=0.3

# ============================================================
# Embedding 后端选择：ollama（本地）或 huggingface（需要下载）
# ============================================================
EMBEDDING_BACKEND=ollama

# --- Ollama Embedding（默认） ---
OLLAMA_EMBEDDING_MODEL=bge-m3:latest

# --- HuggingFace Embedding（备用） ---
# EMBEDDING_MODEL_NAME=BAAI/bge-m3
# EMBEDDING_DEVICE=cpu

# ============================================================
# ChromaDB 配置
# ============================================================
CHROMA_COLLECTION_NAME=food_additives

# 检索返回条数
RETRIEVAL_TOP_K=10

# 对话记忆轮数
CONVERSATION_MAX_ROUNDS=10
