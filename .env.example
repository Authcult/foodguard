# DeepSeek API Key（必填）
# 在 https://platform.deepseek.com 注册获取
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API 地址（一般不需要改）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 模型名（deepseek-chat 是通用模型，deepseek-reasoner 是推理模型）
DEEPSEEK_MODEL=deepseek-chat

# LLM 温度（0-1，越低越精确稳定，越高越有创意）
LLM_TEMPERATURE=0.3

# Embedding 模型（使用 BGE-M3，中文效果好）
# 可选：如果要更轻量，换成 BAAI/bge-small-zh-v1.5
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# Embedding 设备（cpu 或 cuda，本地开发默认 cpu）
EMBEDDING_DEVICE=cpu

# ChromaDB 集合名
CHROMA_COLLECTION_NAME=food_additives

# 检索返回条数
RETRIEVAL_TOP_K=10

# 对话记忆轮数
CONVERSATION_MAX_ROUNDS=10

# 如也有 Qwen API Key（可选，备用）
# QWEN_API_KEY=sk-your-qwen-api-key-here
